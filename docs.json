{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gigstack API",
  "colors": {
    "primary": "#8666FF",
    "light": "#A78BFA",
    "dark": "#6D4AFF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "authentication", "quickstart"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Clients",
            "pages": [
              { "openapi": "GET /clients" },
              { "openapi": "POST /clients" },
              { "openapi": "GET /clients/{id}" },
              { "openapi": "PUT /clients/{id}" },
              { "openapi": "DELETE /clients/{id}" }
            ]
          },
          {
            "group": "Invoices",
            "pages": [
              { "openapi": "GET /invoices" },
              { "openapi": "POST /invoices/income" },
              { "openapi": "GET /invoices/{id}" },
              { "openapi": "POST /invoices/{id}/cancel" }
            ]
          },
          {
            "group": "Payments",
            "pages": [
              { "openapi": "GET /payments" },
              { "openapi": "POST /payments" },
              { "openapi": "GET /payments/{id}" },
              { "openapi": "PUT /payments/{id}" }
            ]
          },
          {
            "group": "Receipts",
            "pages": [
              { "openapi": "GET /receipts" },
              { "openapi": "POST /receipts" },
              { "openapi": "GET /receipts/{id}" }
            ]
          },
          {
            "group": "Services",
            "pages": [
              { "openapi": "GET /services" },
              { "openapi": "POST /services" },
              { "openapi": "GET /services/{id}" },
              { "openapi": "PUT /services/{id}" },
              { "openapi": "DELETE /services/{id}" }
            ]
          },
          {
            "group": "Teams",
            "pages": [
              { "openapi": "GET /teams" },
              { "openapi": "POST /teams" },
              { "openapi": "GET /teams/{id}" },
              { "openapi": "PUT /teams/{id}" }
            ]
          },
          {
            "group": "Users",
            "pages": [
              { "openapi": "GET /users" },
              { "openapi": "GET /users/{id}" }
            ]
          },
          {
            "group": "Documents",
            "pages": [
              { "openapi": "GET /documents/{id}/pdf" },
              { "openapi": "GET /documents/{id}/xml" }
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              { "openapi": "GET /webhooks" },
              { "openapi": "POST /webhooks" },
              { "openapi": "DELETE /webhooks/{id}" }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.gigstack.pro",
          "icon": "gauge"
        },
        {
          "anchor": "Get API Key",
          "href": "https://app.gigstack.pro/settings?tab=api",
          "icon": "key"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:soporte@gigstack.pro"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.gigstack.pro"
    }
  },
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://api.gigstack.io/v2",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/gigstackpro",
      "linkedin": "https://linkedin.com/company/gigstack",
      "github": "https://github.com/disruptive-learning"
    }
  }
}
